# Strapi
NODE_ENV=production
HOST=0.0.0.0
PORT=1337

# Security keys (generate unique long random values)
APP_KEYS=replace_me_1,replace_me_2,replace_me_3,replace_me_4
API_TOKEN_SALT=replace_me
ADMIN_JWT_SECRET=replace_me
TRANSFER_TOKEN_SALT=replace_me
ENCRYPTION_KEY=replace_me
JWT_SECRET=replace_me

# DB (SQLite)
DATABASE_CLIENT=sqlite
DATABASE_FILENAME=.tmp/data.db

# Robokassa
ROBOKASSA_MERCHANT_LOGIN=replace_me
ROBOKASSA_PASSWORD1=replace_me
ROBOKASSA_PASSWORD2=replace_me
ROBOKASSA_HASH_ALGORITHM=md5
ROBOKASSA_IS_TEST=true
ROBOKASSA_PAYMENT_URL=https://auth.robokassa.ru/Merchant/Index.aspx
ROBOKASSA_SUCCESS_URL=http://155.212.218.145:1337/api/payments/robokassa/success
ROBOKASSA_FAIL_URL=http://155.212.218.145:1337/api/payments/robokassa/fail
ROBOKASSA_RESULT_URL=http://155.212.218.145:1337/api/payments/robokassa/result
ROBOKASSA_FRONTEND_SUCCESS_URL=http://155.212.218.145/checkout/success
ROBOKASSA_FRONTEND_FAIL_URL=http://155.212.218.145/checkout/fail
ROBOKASSA_RECEIPT_TAX=none
ROBOKASSA_RECEIPT_PAYMENT_METHOD=full_prepayment
ROBOKASSA_RECEIPT_PAYMENT_OBJECT=commodity
# Optional: osn | usn_income | usn_income_outcome | esn | patent
ROBOKASSA_RECEIPT_SNO=

# SMS provider (optional)
EXOLVE_API_KEY=
EXOLVE_SENDER=
